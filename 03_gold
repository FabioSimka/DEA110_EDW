        ROUND(AVG(f.avg_duration_min), 1)  AS avg_duration_min
    FROM cctb_catalog.ufo_dw.fact_monthly_agg f
    JOIN cctb_catalog.ufo_dw.dim_date d ON f.sk_date = d.date_key
    GROUP BY f.year, f.month_name, d.year_month
    ORDER BY sightings DESC
    LIMIT 10
""").show()

