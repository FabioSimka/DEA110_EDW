from pyspark.sql import functions as F
from delta.tables import DeltaTable

spark.sql("USE cctb_catalog.ufo_dw")
print("Environment ready — dim_date")

df_silver = spark.sql("SELECT * FROM cctb_catalog.ufo_dw.silver_ufo_sightings")
df_silver.createOrReplaceTempView("v_silver")
print(f"Silver rows loaded: {df_silver.count():,}")

%sql
SELECT DISTINCT
        -- Surrogate Key: deterministic hash on the grain columns (year + month)
        -- NOTE: Season is intentionally excluded from the key — it is a derived
        -- attribute of the month. Including it would create duplicate rows for
        -- the same period if the source contains inconsistent season labels.
        xxhash64(year, month)     AS date_key,

        -- Dimension attributes
        cast(event_timestamp as date) AS event_date,      
        year,
        month,
        day(event_date) as day,
        dayofweek(event_date) as dayofweek,
        dayname(event_date) as dayname,
        month_name,
        month_order,              -- zero-padded string for BI tool sort order
        quarter,
        season,
        decade,
        year_month                -- formatted string e.g. '2012-07' for labels
    FROM v_silver
    WHERE year  IS NOT NULL
      AND month IS NOT NULL

DIM_TABLE = "cctb_catalog.ufo_dw.dim_date"

df_dim = spark.sql("""
SELECT DISTINCT
        -- Surrogate Key: deterministic hash on the grain columns (year + month)
        -- NOTE: Season is intentionally excluded from the key — it is a derived
        -- attribute of the month. Including it would create duplicate rows for
        -- the same period if the source contains inconsistent season labels.
        xxhash64(year, month)     AS date_key,

        -- Dimension attributes
        cast(event_timestamp as date) AS event_date,      
        year,
        month,
        day(event_date) as day,
        dayofweek(event_date) as dayofweek,
        dayname(event_date) as dayname,
        month_name,
        month_order,              -- zero-padded string for BI tool sort order
        quarter,
        season,
        decade,
        year_month                -- formatted string e.g. '2012-07' for labels
    FROM v_silver
    WHERE year  IS NOT NULL
      AND month IS NOT NULL
""")

if not spark.catalog.tableExists(DIM_TABLE):
    df_dim.write.format("delta").mode("overwrite").saveAsTable(DIM_TABLE)
    print(f"[CREATE] {DIM_TABLE}")
else:
    DeltaTable.forName(spark, DIM_TABLE).alias("tgt").merge(
        df_dim.alias("src"),
        "tgt.date_key = src.date_key"
    ).whenMatchedUpdate(
        # SCD Type 1: overwrite if season label or decade changed at the source
        condition="tgt.season <> src.season OR tgt.decade <> src.decade",
        set={
            "season"     : "src.season",
            "decade"     : "src.decade",
            "year_month" : "src.year_month"
        }
    ).whenNotMatchedInsertAll().execute()
    print(f"[MERGE]  {DIM_TABLE}")

spark.sql("""
    SELECT
        COUNT(*)             AS total_rows,
        MIN(year)            AS min_year,
        MAX(year)            AS max_year,
        COUNT(DISTINCT year) AS distinct_years,
        COUNT(DISTINCT quarter) AS quarters_present
    FROM cctb_catalog.ufo_dw.dim_date
""").display()

