from pyspark.sql import functions as F
from delta.tables import DeltaTable

spark.sql("USE cctb_catalog.ufo_dw")
print("Environment ready — fact_sighting")

df_silver = spark.sql("SELECT * FROM cctb_catalog.ufo_dw.silver_ufo_sightings")
df_silver.createOrReplaceTempView("v_silver")

# Load all dimension tables as TempViews
spark.sql("SELECT * FROM cctb_catalog.ufo_dw.dim_date").createOrReplaceTempView("v_dim_date")
spark.sql("SELECT * FROM cctb_catalog.ufo_dw.dim_time").createOrReplaceTempView("v_dim_time")
spark.sql("SELECT * FROM cctb_catalog.ufo_dw.dim_location").createOrReplaceTempView("v_dim_location")
spark.sql("SELECT * FROM cctb_catalog.ufo_dw.dim_ufo_shape").createOrReplaceTempView("v_dim_ufo_shape")
spark.sql("SELECT * FROM cctb_catalog.ufo_dw.dim_duration").createOrReplaceTempView("v_dim_duration")

print("Silver and all dimensions loaded as TempViews")

print(f"Silver rows loaded: {df_silver.count():,}")

source_df = spark.sql("""

    SELECT DISTINCT

        -- Original Silver fields (business attributes carried into the fact)
        s.event_timestamp,
        s.date_documented,
        s.year,
        s.month,
        s.hour,
        s.season,
        s.country_code,
        s.country,
        s.region,
        s.locale,
        s.latitude,
        s.longitude,
        s.ufo_shape,
        s.duration_seconds,
        s.duration_minutes,
        s.duration_category,
        s.time_of_day,
        s.is_usa,
        s.description,
        s._ingestion_ts,

        -- Additive measure: always 1 per row, allows COUNT via SUM in BI tools
        1 AS sighting_count,

        -- SK columns resolved by joining dimension tables on their natural keys
        d_date.date_key      AS sk_date,
        d_time.time_key      AS sk_time,
        d_loc.location_key   AS sk_location,
        d_shp.shape_key      AS sk_ufo_shape,
        d_dur.duration_key   AS sk_duration

    FROM v_silver AS s

    LEFT JOIN v_dim_date AS d_date
        ON  s.year  = d_date.year
        AND s.month = d_date.month

    LEFT JOIN v_dim_time AS d_time
        ON s.hour = d_time.hour

    LEFT JOIN v_dim_location AS d_loc
        ON  COALESCE(s.country_code, '') = COALESCE(d_loc.country_code, '')
        AND COALESCE(s.country,      '') = COALESCE(d_loc.country,      '')
        AND COALESCE(s.region,       '') = COALESCE(d_loc.region,       '')
        AND COALESCE(s.locale,       '') = COALESCE(d_loc.locale,       '')
        AND COALESCE(s.latitude,      0) = COALESCE(d_loc.latitude,      0)
        AND COALESCE(s.longitude,     0) = COALESCE(d_loc.longitude,     0)

    LEFT JOIN v_dim_ufo_shape AS d_shp
        ON s.ufo_shape = d_shp.ufo_shape

    LEFT JOIN v_dim_duration AS d_dur
        ON s.duration_category = d_dur.duration_category

    WHERE s.year IS NOT NULL

""")

print(f"Source DataFrame rows: {source_df.count():,}")
source_df.printSchema()

source_df = source_df.withColumn(
    "sighting_key",
    F.xxhash64(
        F.coalesce(F.col("event_timestamp").cast("string"), F.lit("")),
        F.coalesce(F.col("country"),                         F.lit("")),
        F.coalesce(F.col("region"),                          F.lit("")),
        F.coalesce(F.col("locale"),                          F.lit("")),
        F.coalesce(F.col("ufo_shape"),                       F.lit("")),
        F.coalesce(F.col("duration_seconds").cast("string"), F.lit(""))
    )
)

source_df.createOrReplaceTempView("v_fact_source")
print("sighting_key column added")

FACT_TABLE = "cctb_catalog.ufo_dw.fact_sighting"
if not spark.catalog.tableExists(FACT_TABLE):
    (
        source_df
        .write
        .format("delta")
        .mode("overwrite")
        .option("overwriteSchema", "true")
        .saveAsTable(FACT_TABLE)
    )
    print(f"[CREATE] {FACT_TABLE}")

else:
    DeltaTable.forName(spark, FACT_TABLE).alias("tgt").merge(
        source_df.alias("src"),
        "tgt.sighting_key = src.sighting_key"
    ).whenMatchedUpdate(
        # Update only if duration or timestamp was corrected at the source
        condition="""
            tgt.duration_seconds <> src.duration_seconds  OR
            tgt.event_timestamp  <> src.event_timestamp
        """,
        set={
            "duration_seconds" : "src.duration_seconds",
            "duration_minutes" : "src.duration_minutes",
            "event_timestamp"  : "src.event_timestamp",
            "sk_duration"      : "src.sk_duration",
            "_ingestion_ts"    : "src._ingestion_ts"
        }
    ).whenNotMatchedInsertAll().execute()
    print(f"[MERGE]  {FACT_TABLE}")

row_count = spark.sql(f"SELECT COUNT(*) AS n FROM {FACT_TABLE}").collect()[0][0]
print(f"\nTotal rows in fact_sighting : {row_count:,}")

spark.sql("""
    SELECT
        COUNT(*)                        AS total_rows,
        COUNT(DISTINCT sighting_key)    AS distinct_keys,
        COUNT(DISTINCT sk_location)     AS distinct_locations,
        COUNT(DISTINCT sk_ufo_shape)    AS distinct_shapes,
        ROUND(AVG(duration_minutes), 2) AS avg_duration_min,
        ROUND(MAX(duration_minutes), 2) AS max_duration_min,
