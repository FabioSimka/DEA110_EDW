## DIM_LOCATION Table

from pyspark.sql import functions as F
from delta.tables import DeltaTable

spark.sql("USE cctb_catalog.ufo_dw")
print("Environment ready — dim_location")

df_silver = spark.sql("SELECT * FROM cctb_catalog.ufo_dw.silver_ufo_sightings")
df_silver.createOrReplaceTempView("v_silver")
print(f"Silver rows loaded: {df_silver.count():,}")

DIM_TABLE = "cctb_catalog.ufo_dw.dim_location"

df_dim = spark.sql("""
    SELECT DISTINCT
        -- Surrogate Key: hash over all location-defining fields
        -- COALESCE maps NULLs to '' so unknown locations still get a consistent key
        -- Coordinates are already rounded to 4 decimal places in the Silver layer
        xxhash64(
            COALESCE(country_code, ''),
            COALESCE(country,      ''),
            COALESCE(region,       ''),
            COALESCE(locale,       ''),
            COALESCE(CAST(latitude  AS STRING), ''),
            COALESCE(CAST(longitude AS STRING), '')
        )               AS location_key,

        -- Dimension attributes
        country_code,
        country,
        region,
        locale,
        latitude,
        longitude,
        is_usa          -- 'USA' | 'Other Countries' — supports BQ6 slicing
    FROM v_silver
    -- Records without a country are still included: country = NULL is a valid
    -- 'unknown location' state, mapped to is_usa = 'Other Countries'
""")

if not spark.catalog.tableExists(DIM_TABLE):
    df_dim.write.format("delta").mode("overwrite").saveAsTable(DIM_TABLE)
    print(f"[CREATE] {DIM_TABLE}")
else:
    DeltaTable.forName(spark, DIM_TABLE).alias("tgt").merge(
        df_dim.alias("src"),
        "tgt.location_key = src.location_key"
    ).whenMatchedUpdate(
        # SCD Type 1: overwrite if the country or region name was corrected at source
        condition="""
            tgt.country      <> src.country       OR
            tgt.region       <> src.region         OR
            tgt.country_code <> src.country_code
        """,
        set={
            "country"      : "src.country",
            "region"       : "src.region",
            "country_code" : "src.country_code",
            "is_usa"       : "src.is_usa"
        }
    ).whenNotMatchedInsertAll().execute()
    print(f"[MERGE]  {DIM_TABLE}")
spark.sql("""
    SELECT
        COUNT(*)                                             AS total_rows,
        COUNT(DISTINCT country)                              AS distinct_countries,
        COUNT(DISTINCT region)                               AS distinct_regions,
        SUM(CASE WHEN country IS NULL THEN 1 ELSE 0 END)     AS unknown_country_rows,
        SUM(CASE WHEN is_usa = 'USA'  THEN 1 ELSE 0 END)     AS usa_locations
    FROM cctb_catalog.ufo_dw.dim_location
""").display()

# Top 10 countries by number of distinct locations
spark.sql("""
    SELECT country, COUNT(*) AS location_count
    FROM cctb_catalog.ufo_dw.dim_location
    WHERE country IS NOT NULL
    GROUP BY country
    ORDER BY location_count DESC
    LIMIT 10
""").display()

