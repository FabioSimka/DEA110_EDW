df_dim = spark.sql("""
    SELECT DISTINCT
        -- Surrogate Key: hash on hour — produces at most 24 unique keys
        xxhash64(hour)      AS time_key,

        -- Dimension attributes
        hour,
        hour_label,         -- formatted string e.g. '21:00'
        time_of_day,        -- time band: Night / Morning / Afternoon / Evening
        -- is_night: convenience flag for night-time filtering in BI tools
        CASE WHEN hour < 6 OR hour >= 20 THEN 1 ELSE 0 END AS is_night
    FROM v_silver
    WHERE hour IS NOT NULL
      AND hour BETWEEN 0 AND 23   -- guard against malformed hour values
""")

if not spark.catalog.tableExists(DIM_TABLE):
    df_dim.write.format("delta").mode("overwrite").saveAsTable(DIM_TABLE)
    print(f"[CREATE] {DIM_TABLE}")
else:
    DeltaTable.forName(spark, DIM_TABLE).alias("tgt").merge(
        df_dim.alias("src"),
        "tgt.time_key = src.time_key"
    ).whenMatchedUpdate(
        condition="tgt.time_of_day <> src.time_of_day",
        set={
            "time_of_day" : "src.time_of_day",
            "hour_label"  : "src.hour_label"
        }
    ).whenNotMatchedInsertAll().execute()
    print(f"[MERGE]  {DIM_TABLE}")

spark.sql("""
    SELECT
        COUNT(*)      AS total_rows,
        MIN(hour)     AS min_hour,
        MAX(hour)     AS max_hour,
