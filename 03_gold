## DIM_DURATION Table

from pyspark.sql import functions as F
from delta.tables import DeltaTable

spark.sql("USE cctb_catalog.ufo_dw")
print("Environment ready — dim_duration")

DIM_TABLE = "cctb_catalog.ufo_dw.dim_duration"

# Static dimension: 5 business-defined duration bands
# These bands match the duration_category values computed in the Silver layer,
# ensuring every fact row can be joined to this dimension without orphan records
df_dim = spark.sql("""
    SELECT
        xxhash64(duration_category) AS duration_key,
        duration_category,
        min_seconds,
        max_seconds,
        sort_order                  -- integer used for correct ordering in BI tools
    FROM (
        SELECT '1. < 1 min'    AS duration_category,    0 AS min_seconds,        59 AS max_seconds, 1 AS sort_order
        UNION ALL SELECT '2. 1-5 min',                 60,                      299,               2
        UNION ALL SELECT '3. 5-15 min',               300,                      899,               3
        UNION ALL SELECT '4. 15-60 min',              900,                     3599,               4
        UNION ALL SELECT '5. > 1 hour',              3600,               999999999,               5
    )
""")

if not spark.catalog.tableExists(DIM_TABLE):
    df_dim.write.format("delta").mode("overwrite").saveAsTable(DIM_TABLE)
    print(f"[CREATE] {DIM_TABLE}")
else:
    DeltaTable.forName(spark, DIM_TABLE).alias("tgt").merge(
        df_dim.alias("src"),
        "tgt.duration_key = src.duration_key"
    ).whenMatchedUpdate(
        # Update if band boundaries were redefined
        condition="tgt.max_seconds <> src.max_seconds OR tgt.min_seconds <> src.min_seconds",
        set={
            "max_seconds" : "src.max_seconds",
            "min_seconds" : "src.min_seconds"
        }
    ).whenNotMatchedInsertAll().execute()
    print(f"[MERGE]  {DIM_TABLE}")
# Should always contain exactly 5 rows ordered by sort_order
spark.sql("SELECT * FROM cctb_catalog.ufo_dw.dim_duration ORDER BY sort_order").display()

