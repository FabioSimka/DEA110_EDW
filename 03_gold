## FACT MONTHLY Table

from pyspark.sql import functions as F
from delta.tables import DeltaTable

spark.sql("USE cctb_catalog.ufo_dw")
print("Environment ready — fact_monthly_agg")

df_silver = spark.sql("SELECT * FROM cctb_catalog.ufo_dw.silver_ufo_sightings")
df_silver.createOrReplaceTempView("v_silver")

# Dimensions loaded as TempViews — Databricks traces lineage automatically
spark.sql("SELECT * FROM cctb_catalog.ufo_dw.dim_date").createOrReplaceTempView("v_dim_date")
spark.sql("SELECT * FROM cctb_catalog.ufo_dw.dim_location").createOrReplaceTempView("v_dim_location")
spark.sql("SELECT * FROM cctb_catalog.ufo_dw.dim_ufo_shape").createOrReplaceTempView("v_dim_ufo_shape")

print("Silver and dimensions loaded")

print(f"Silver rows loaded: {df_silver.count():,}")

# Step 1: aggregate Silver to monthly grain, then join dimensions for SKs
# dim_time is not joined here — time-of-day is not meaningful at monthly grain
# dim_duration is not joined here — duration bands collapse across the month

source_df = spark.sql("""

    SELECT

        -- Original aggregated fields
        s.year,
        s.month,
        s.month_name,
        s.quarter,
        COALESCE(s.country, 'Unknown')   AS country,
        s.country_code,
        s.is_usa,
        s.shape_grouped,

        -- Aggregated measures
        COUNT(*)                                                       AS total_sightings,
        SUM(s.duration_seconds)                                        AS total_duration_sec,
        -- avg_duration_min is semi-additive: never SUM across countries
        ROUND(AVG(s.duration_minutes), 4)                              AS avg_duration_min,
        -- max_duration_min is non-additive
        ROUND(MAX(s.duration_minutes), 4)                              AS max_duration_min,
        -- Percentage of sightings in night hours (hour < 6 or >= 20)
        ROUND(
            100.0 * SUM(CASE WHEN s.hour < 6 OR s.hour >= 20 THEN 1 ELSE 0 END)
                  / COUNT(*), 2
        )                                                              AS pct_night_sightings,

        -- SKs resolved from dimension joins
        d_date.date_key      AS sk_date,
        d_loc.location_key   AS sk_location,
        d_shp.shape_key      AS sk_ufo_shape,

        CURRENT_TIMESTAMP()  AS _agg_ts

    FROM v_silver AS s

    LEFT JOIN v_dim_date AS d_date
        ON  s.year  = d_date.year
        AND s.month = d_date.month

    -- Location join at country level (region and locale are blank for aggregation)
    LEFT JOIN v_dim_location AS d_loc
        ON  COALESCE(s.country_code, '') = COALESCE(d_loc.country_code, '')
        AND COALESCE(s.country,      '') = COALESCE(d_loc.country,      '')
        AND d_loc.region   = ''
        AND d_loc.locale   = ''
        AND d_loc.latitude  = 0
        AND d_loc.longitude = 0

    -- Shape join using the grouped label (coarser than fact_sighting)
    LEFT JOIN v_dim_ufo_shape AS d_shp
        ON s.shape_grouped = d_shp.ufo_shape

    WHERE s.year IS NOT NULL
    GROUP BY
        s.year, s.month, s.month_name, s.quarter,
        s.country, s.country_code, s.is_usa,
        s.shape_grouped,
        d_date.date_key,
        d_loc.location_key,
        d_shp.shape_key

""")

source_df = source_df.drop("_silver_ts", "_source_file")
print(f"Source DataFrame rows: {source_df.count():,}")

source_df = source_df.withColumn(
    "monthly_key",
    F.xxhash64(
        F.coalesce(F.col("year").cast("string"),  F.lit("")),
        F.coalesce(F.col("month").cast("string"), F.lit("")),
        F.coalesce(F.col("country"),              F.lit("")),
        F.coalesce(F.col("shape_grouped"),        F.lit(""))
    )
)

source_df.createOrReplaceTempView("v_fact_monthly_source")
print("monthly_key column added")

FACT_TABLE = "cctb_catalog.ufo_dw.fact_monthly_agg"

if not spark.catalog.tableExists(FACT_TABLE):
    (
        source_df
        .write
        .format("delta")
        .mode("overwrite")
        .option("overwriteSchema", "true")
        .saveAsTable(FACT_TABLE)
    )
    print(f"[CREATE] {FACT_TABLE}")

else:
    DeltaTable.forName(spark, FACT_TABLE).alias("tgt").merge(
        source_df.alias("src"),
        "tgt.monthly_key = src.monthly_key"
    ).whenMatchedUpdate(
        # Re-aggregate if totals or averages changed (e.g. source corrections)
        condition="""
            tgt.total_sightings  <> src.total_sightings  OR
            tgt.avg_duration_min <> src.avg_duration_min
        """,
        set={
            "total_sightings"     : "src.total_sightings",
            "total_duration_sec"  : "src.total_duration_sec",
            "avg_duration_min"    : "src.avg_duration_min",
            "max_duration_min"    : "src.max_duration_min",
            "pct_night_sightings" : "src.pct_night_sightings",
            "_agg_ts"             : "src._agg_ts"
        }
    ).whenNotMatchedInsertAll().execute()
    print(f"[MERGE]  {FACT_TABLE}")

row_count = spark.sql(f"SELECT COUNT(*) AS n FROM {FACT_TABLE}").collect()[0][0]
print(f"\nTotal rows in fact_monthly_agg : {row_count:,}")

spark.sql("""
    SELECT
        COUNT(*)                        AS total_rows,
        SUM(total_sightings)            AS grand_total_sightings,
        MIN(year)                       AS min_year,
        MAX(year)                       AS max_year,
        COUNT(DISTINCT country)         AS distinct_countries,
        COUNT(DISTINCT shape_grouped)   AS distinct_shape_groups
    FROM cctb_catalog.ufo_dw.fact_monthly_agg
""").display()

spark.sql("""
    SELECT 'sk_date'      AS sk_column, COUNT(*) AS orphan_rows
    FROM cctb_catalog.ufo_dw.fact_monthly_agg WHERE sk_date IS NULL
    UNION ALL
    SELECT 'sk_location',  COUNT(*) FROM cctb_catalog.ufo_dw.fact_monthly_agg WHERE sk_location IS NULL
    UNION ALL
    SELECT 'sk_ufo_shape', COUNT(*) FROM cctb_catalog.ufo_dw.fact_monthly_agg WHERE sk_ufo_shape IS NULL
""").show()

spark.sql("""
    SELECT
        f.year,
        f.month_name,
        d.year_month,
